# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_NAME=next_gen_inventory

# JWT — generate strong values: `openssl rand -base64 48`
# Two independent secrets so a leaked access token can't forge refresh tokens.
JWT_SECRET=replace-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated origin allowlist
CORS_ORIGINS=http://localhost:3000

# Rate limiting (per IP)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# Optional: Sentry DSN for server-side error reporting. Empty = disabled.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

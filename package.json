{
  "name": "ngim-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Root tooling (Husky + lint-staged) for the NGIM workspace.",
  "scripts": {
    "prepare": "husky",
    "lint:backend": "npm --prefix backend run lint",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:backend": "npm --prefix backend test"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,yml,yaml}": "prettier --write --ignore-unknown"
  }
}
